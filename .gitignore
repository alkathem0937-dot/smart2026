# ═══════════════════════════════════════════════════
# SmartJudi .gitignore
# ═══════════════════════════════════════════════════

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
*.whl

# ─── Python Virtual Environments ───
my_smart/
my_smart_new/
venv/
.venv/
env/

# ─── Django ───
smartju/db.sqlite3
smartju/media/
smartju/staticfiles/
smartju/mysite_data.json
smartju/data_backup.json

# ─── Database Files ───
*.db
*.sqlite3
rag_engine/chroma_db/

# ─── SQL Dumps (keep only schema) ───
*.sql
!pg_schema.sql

# ─── Flutter / Dart ───
/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/doc/api/
**/ios/Flutter/.last_build_id
app.*.symbols
app.*.map.json

# ─── Android ───
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/.kotlin/
/android/app/build/

# ─── Environment Variables ───
.env
.env.local
.env.*.local
microservices/.env

# ─── IDE ───
.idea/
*.iml
*.ipr
*.iws
.vscode/settings.json

# ─── OS Files ───
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*.bak

# ─── Logs ───
*.log

# ─── Large Data ───
*.data
.import_checkpoint.json

# ─── Misc ───
*.class
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# ─── QA Reports (captured in docs/) ───
QA_REPORTS/

# ─── Temp scripts ───
scripts/_analyze_project.py

# ─── Data dumps / exports ───
smartju/chunked_import*.py
smartju/export_data.py
smartju/*.json
!smartju/package.json
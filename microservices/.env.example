# SmartJudi Microservices Environment Configuration
# Copy this to .env and fill in the values

# Database password (shared across all Postgres instances)
DB_PASSWORD=smartjudi_secret

# JWT signing key — MUST match the monolith SECRET_KEY during migration
JWT_SECRET_KEY=your-django-secret-key-here

# Internal API key for service-to-service communication
INTERNAL_API_KEY=your-internal-api-key-here

# AI Service
GROQ_API_KEY=your-groq-api-key-here
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small

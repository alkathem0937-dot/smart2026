# Sync Agent (Local office server)

# Tenant
TENANT_ID=office-1
TENANT_API_KEY=PASTE_TENANT_API_KEY_HERE

# Local PostgreSQL (Source of truth)
LOCAL_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/smartjudi

# Client-side encryption passphrase (keep local only)
BACKUP_PASSPHRASE=CHANGE_ME_STRONG

# Optional: full path to pg_dump.exe (if not on PATH)
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe

# Control Panel (Cloud)
CONTROL_PANEL_BASE_URL=https://control.your-domain.com

# Output
BACKUP_OUTPUT_DIR=./backups
